PORT=3001
JWT_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:3000

# --- Database (use ONE style) ---
# Managed Postgres (Railway, Supabase, Neon, etc.) — typical for production
DATABASE_URL=postgresql://user:pass@host:5432/dbname
DB_SSL=true

# Local / Docker Compose without DATABASE_URL (host "db" when RUNNING_IN_DOCKER=true)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=password
# DB_NAME=ai_notes
# RUNNING_IN_DOCKER=true
